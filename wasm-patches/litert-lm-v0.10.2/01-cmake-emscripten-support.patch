-        CMAKE_ARGS
-            "-DLITERTLM_PROJECT_ROOT=${LITERTLM_PROJECT_ROOT}"
+        # Force a clean native build environment for the host prebuild
+        # stage. ExternalProject_Add inherits the parent's env, which under
+        # emcmake puts CC=emcc / CMAKE_TOOLCHAIN_FILE=Emscripten.cmake into
+        # scope. Run cmake via -E env --unset on BOTH the configure and
+        # build steps — the build step recursively spawns child cmake
+        # invocations (for absl/gtest/re2/etc. ExternalProjects inside the
+        # prebuild's own CMakeLists.txt) which would otherwise re-pick-up
+        # emcc from their inherited env.
+        # protobuf v6.31.1's protoc-gen-upbdefs/protoc-gen-upb link against
+        # libabsl_time_zone.a which references CoreFoundation symbols
+        # (CFStringGetMaximumSizeForEncoding, CFTimeZoneCopyDefault, ...) on
+        # macOS. Their CMakeLists doesn't add `-framework CoreFoundation`
+        # automatically, so we inject it via LDFLAGS env var, which CMake
+        # picks up at configure time and propagates to all child Makefiles.
+        # Linux/other hosts: the var is empty and the export is a no-op.
+        #
+        # CARGO_TARGET_<triple>_LINKER and CC_<triple>/CXX_<triple> override
+        # the inherited CC=emcc/CXX=em++ for tokenizers-cpp's Rust crates
+        # (onig_sys uses cc-rs which would otherwise pick up emcc's clang
+        # for native host compilation, failing with "stdlib.h not found").
+        CONFIGURE_COMMAND ${CMAKE_COMMAND} -E env
+            --unset=CC --unset=CXX
+            --unset=CMAKE_TOOLCHAIN_FILE
+            --unset=EMSDK --unset=EMSDK_NODE --unset=EMSDK_PYTHON
+            --unset=EMCC_CFLAGS --unset=EMCC_FORCE_STDLIBS
+            "LDFLAGS=$<$<PLATFORM_ID:Darwin>:-framework CoreFoundation>"
+            "CC_aarch64_apple_darwin=${LITERTLM_HOST_C_COMPILER}"
+            "CXX_aarch64_apple_darwin=${LITERTLM_HOST_CXX_COMPILER}"
+            "CC_x86_64_apple_darwin=${LITERTLM_HOST_C_COMPILER}"
+            "CXX_x86_64_apple_darwin=${LITERTLM_HOST_CXX_COMPILER}"
+            "CC_x86_64_unknown_linux_gnu=${LITERTLM_HOST_C_COMPILER}"
+            "CXX_x86_64_unknown_linux_gnu=${LITERTLM_HOST_CXX_COMPILER}"
+            "CC_aarch64_unknown_linux_gnu=${LITERTLM_HOST_C_COMPILER}"
+            "CXX_aarch64_unknown_linux_gnu=${LITERTLM_HOST_CXX_COMPILER}"
+            ${CMAKE_COMMAND} -S <SOURCE_DIR> -B <BINARY_DIR>
+                "-DCMAKE_C_COMPILER=${LITERTLM_HOST_C_COMPILER}"
+                "-DCMAKE_CXX_COMPILER=${LITERTLM_HOST_CXX_COMPILER}"
+                "-DLITERTLM_PROJECT_ROOT=${LITERTLM_PROJECT_ROOT}"
+                "-DCMAKE_BUILD_TYPE=Release"
+
+        BUILD_COMMAND ${CMAKE_COMMAND} -E env
+            --unset=CC --unset=CXX
+            --unset=CMAKE_TOOLCHAIN_FILE
+            --unset=EMSDK --unset=EMSDK_NODE --unset=EMSDK_PYTHON
+            --unset=EMCC_CFLAGS --unset=EMCC_FORCE_STDLIBS
+            "LDFLAGS=$<$<PLATFORM_ID:Darwin>:-framework CoreFoundation>"
+            "CC_aarch64_apple_darwin=${LITERTLM_HOST_C_COMPILER}"
+            "CXX_aarch64_apple_darwin=${LITERTLM_HOST_CXX_COMPILER}"
+            "CC_x86_64_apple_darwin=${LITERTLM_HOST_C_COMPILER}"
+            "CXX_x86_64_apple_darwin=${LITERTLM_HOST_CXX_COMPILER}"
+            "CC_x86_64_unknown_linux_gnu=${LITERTLM_HOST_C_COMPILER}"
+            "CXX_x86_64_unknown_linux_gnu=${LITERTLM_HOST_CXX_COMPILER}"
+            "CC_aarch64_unknown_linux_gnu=${LITERTLM_HOST_C_COMPILER}"
+            "CXX_aarch64_unknown_linux_gnu=${LITERTLM_HOST_CXX_COMPILER}"
+            ${CMAKE_COMMAND} --build <BINARY_DIR>
 
         INSTALL_COMMAND ""
     )
@@ -94,6 +171,27 @@ ExternalProject_Add(
         "-DLITERTLM_HOST_FLATC=${LITERTLM_HOST_FLATC}"
         "-DLITERTLM_HOST_FLATC_BIN_DIR=${LITERTLM_HOST_FLATC_BIN_DIR}"
 
+    # During the cross stage's build, cargo invokes Rust crates' build.rs
+    # scripts which need to compile + link a HOST executable (not wasm).
+    # The default build env has CC=emcc/CXX=em++ from the parent emcmake;
+    # cargo's cc-rs picks those up and emcc tries to link a host binary
+    # (failing with `wasm-ld: error: unknown argument: --as-needed` etc).
+    # Setting per-host-triple CC_/CXX_ env vars steers cc-rs back to
+    # native clang for build scripts while leaving CC=emcc in place for
+    # the actual cross compile.
+    BUILD_COMMAND ${CMAKE_COMMAND} -E env
+        "CC_aarch64_apple_darwin=${LITERTLM_HOST_C_COMPILER}"
+        "CXX_aarch64_apple_darwin=${LITERTLM_HOST_CXX_COMPILER}"
+        "CC_x86_64_apple_darwin=${LITERTLM_HOST_C_COMPILER}"
+        "CXX_x86_64_apple_darwin=${LITERTLM_HOST_CXX_COMPILER}"
+        "CC_x86_64_unknown_linux_gnu=${LITERTLM_HOST_C_COMPILER}"
+        "CXX_x86_64_unknown_linux_gnu=${LITERTLM_HOST_CXX_COMPILER}"
+        "CC_aarch64_unknown_linux_gnu=${LITERTLM_HOST_C_COMPILER}"
+        "CXX_aarch64_unknown_linux_gnu=${LITERTLM_HOST_CXX_COMPILER}"
+        "CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_LINKER=${LITERTLM_HOST_C_COMPILER}"
+        "CARGO_TARGET_AARCH64_APPLE_DARWIN_LINKER=${LITERTLM_HOST_C_COMPILER}"
+        ${CMAKE_COMMAND} --build <BINARY_DIR>
+
     INSTALL_COMMAND ""
     BUILD_ALWAYS TRUE
 )
diff --git a/cmake/modules/fetch_content.cmake b/cmake/modules/fetch_content.cmake
index a3f24e8..18aa052 100644
--- a/cmake/modules/fetch_content.cmake
+++ b/cmake/modules/fetch_content.cmake
@@ -80,12 +80,22 @@ FetchContent_Populate(llguidance)
 
 # --- LibPNG ---
 set(LIBPNG_SRC_DIR ${THIRD_PARTY_DIR}/libpng CACHE PATH "Path to libpng source directory")
+# libpng v1.6.40's pngpriv.h includes <fp.h> when TARGET_OS_MAC is defined,
+# but TARGET_OS_MAC is set on *modern* macOS too (and fp.h is a Classic Mac
+# header that no longer exists). Strip TARGET_OS_MAC from that conditional
+# so we fall through to the <math.h> branch. Same patch is needed on emcc
+# because emscripten's libc doesn't have <fp.h> either.
+#
+# Use sed in-place. macOS sed needs `-i ''` (BSD), GNU sed accepts `-i`.
 FetchContent_Declare(
   libpng_lib
   GIT_REPOSITORY https://github.com/glennrp/libpng.git
   GIT_TAG v1.6.40
   GIT_SHALLOW true
   SOURCE_DIR ${LIBPNG_SRC_DIR}
+  PATCH_COMMAND
+    ${CMAKE_COMMAND} -DPNGPRIV_H=${LIBPNG_SRC_DIR}/pngpriv.h
+                     -P ${LITERTLM_PACKAGES_DIR}/../scripts/patch_libpng_pngpriv.cmake
 )
 block()
   set(PNG_SHARED OFF)
@@ -94,7 +104,19 @@ block()
   set(SKIP_INSTALL_ALL ON)
 
   # Handle ZLIB dependency injection for PNG
-  if(TARGET zlib)
+  if(EMSCRIPTEN)
+    # emscripten ships zlib via its port system. `embuilder build zlib`
+    # populates the library at this path; the CI workflow runs that
+    # ahead of time. Setting these as CACHE FORCE overrides libpng's
+    # find_package(ZLIB REQUIRED) so we don't depend on the FetchContent
+    # zlib_lib target order or on the cross-stage having a `zlib` target.
+    set(_emcc_sysroot "$ENV{EMSDK}/upstream/emscripten/cache/sysroot")
+    set(ZLIB_INCLUDE_DIR "${_emcc_sysroot}/include" CACHE PATH "emscripten zlib include" FORCE)
+    set(ZLIB_LIBRARY "${_emcc_sysroot}/lib/wasm32-emscripten/libz.a" CACHE FILEPATH "emscripten zlib library" FORCE)
+    set(ZLIB_FOUND TRUE CACHE BOOL "emscripten zlib found" FORCE)
+    add_compile_options(-sUSE_ZLIB=1)
+    add_link_options(-sUSE_ZLIB=1)
+  elseif(TARGET zlib)
     get_target_property(ZLIB_INCLUDE_DIR zlib INTERFACE_INCLUDE_DIRECTORIES)
     set(ZLIB_LIBRARY zlib)
   elseif(TARGET zlibstatic)
@@ -221,21 +243,34 @@ endif()
 
 # --- ZLIB ---
 set(ZLIB_SRC_DIR ${THIRD_PARTY_DIR}/zlib CACHE PATH "Path to zlib source directory")
-FetchContent_Declare(
-  zlib_lib
-  GIT_REPOSITORY https://github.com/madler/zlib
-  GIT_TAG master
-  GIT_SHALLOW true
-  SOURCE_DIR ${ZLIB_SRC_DIR}
-)
-block()
-  set(BUILD_SHARED_LIBS OFF)
-  FetchContent_MakeAvailable(zlib_lib)
-endblock()
-if(TARGET zlibstatic)
-  add_library(zlib_lib ALIAS zlibstatic)
-elseif(TARGET zlib)
-  add_library(zlib_lib ALIAS zlib)
+if(EMSCRIPTEN)
+  # Skip the zlib FetchContent build entirely under emcc — zlib master's
+  # CMakeLists unconditionally declares an `add_library(zlib SHARED ...)`
+  # target which emcc rejects ("target platform does not support dynamic
+  # linking"). Instead we lean on emscripten's bundled zlib port (built
+  # ahead of time via `embuilder build zlib` in the CI workflow) and
+  # expose `zlib_lib` as an INTERFACE target that propagates the
+  # -sUSE_ZLIB=1 link flag to consumers.
+  add_library(zlib_lib INTERFACE)
+  target_compile_options(zlib_lib INTERFACE -sUSE_ZLIB=1)
+  target_link_options(zlib_lib INTERFACE -sUSE_ZLIB=1)
+else()
+  FetchContent_Declare(
+    zlib_lib
+    GIT_REPOSITORY https://github.com/madler/zlib
+    GIT_TAG master
+    GIT_SHALLOW true
+    SOURCE_DIR ${ZLIB_SRC_DIR}
+  )
+  block()
+    set(BUILD_SHARED_LIBS OFF)
+    FetchContent_MakeAvailable(zlib_lib)
+  endblock()
+  if(TARGET zlibstatic)
+    add_library(zlib_lib ALIAS zlibstatic)
+  elseif(TARGET zlib)
+    add_library(zlib_lib ALIAS zlib)
+  endif()
 endif()
 
